{
  "name": "@labdigital/storyblok-graphql-codegen-terraform",
  "author": "Lab Digital",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/labd/storyblok-graphql-codegen-terraform.git"
  },
  "module": "dist/index.mjs",
  "files": [
    "dist",
    "storyblok-base.graphql"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./resolvers": "./dist/resolvers.js"
  },
  "version": "0.15.0",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "resolvers": [
        "dist/resolvers.d.ts"
      ]
    }
  },
  "packageManager": "pnpm@9.15.9",
  "keywords": [
    "graphql",
    "codegen",
    "terraform",
    "storyblok"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "postbuild": "cp package.json dist",
    "lint": "eslint src/ test/",
    "example": "pnpm build && graphql-codegen --config examples/codegen.yml",
    "publish:ci": "pnpm build && pnpm changeset publish"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "eslint"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@graphql-codegen/cli": "^6.2.0",
    "@graphql-tools/merge": "9",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.25.1",
    "typescript-eslint": "^8.31.1",
    "graphql": "^16.11.0",
    "graphql-tag": "2",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "size-limit": "^11.2.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@graphql-codegen/plugin-helpers": "^6.2.0",
    "change-case": "^5.4.4",
    "terraform-generator": "^6.5.0"
  },
  "peerDependencies": {
    "@graphql-tools/merge": "9",
    "graphql": "16",
    "graphql-tag": "2"
  },
  "pnpm": {
    "overrides": {
      "graphql": "16.11.0",
      "lodash": ">=4.18.0"
    }
  },
  "resolutions": {
    "graphql": "16.11.0",
    "lodash": ">=4.18.0"
  }
}
